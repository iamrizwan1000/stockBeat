APP_NAME=StockBeat
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Sign up at https://sentry.io, create a Laravel project, and paste its DSN here.
# Leave blank to disable Sentry (it no-ops silently with no DSN set).
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER="resend"
MAIL_SCHEME=null
MAIL_HOST="smtp.resend.com"
MAIL_PORT="587"
MAIL_USERNAME="resend"
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Path to the Firebase Admin SDK service-account JSON (never commit the file itself —
# storage/app/private/ is gitignored by default).
FIREBASE_CREDENTIALS=/var/www/html/storage/app/private/firebase/service-account.json

# RevenueCat webhook (Plan §6.1) — a value YOU generate, not one RevenueCat
# issues. Set the same value as the Authorization header on the webhook in
# the RevenueCat dashboard (Project Settings -> Integrations -> Webhooks).
REVENUECAT_WEBHOOK_SECRET=

# Inbound email (Plan §4.5/§4.9/§7.7) — a value YOU generate, checked against
# whatever inbound-email provider (SES+Lambda, Mailgun, Postmark) is
# eventually wired to POST /hooks/email-inbound. No provider is connected yet.
INBOUND_EMAIL_WEBHOOK_SECRET=

# Twilio (Plan §8.2 SMS) — from your Twilio Console (console.twilio.com):
# Account SID + Auth Token from the dashboard home, Messaging Service SID
# from Messaging -> Services (a Messaging Service handles sender-number
# pooling/A2P 10DLC registration for you, simpler than a single From number).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# Social sign-in (Plan §4.1) — validated against the `aud` claim on every
# Apple/Google id_token the mobile app sends to POST /auth/social.
# Apple: the Services ID from developer.apple.com (Certificates, Identifiers
# & Profiles -> Identifiers -> your Services ID), not the app's Bundle ID.
# Google: an OAuth 2.0 client ID from console.cloud.google.com (the iOS/
# Android client ID the mobile app itself signs in with).
APPLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
